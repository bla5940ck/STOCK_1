# LINE Messaging API Configuration
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_CHANNEL_SECRET=your_channel_secret_here

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=False
LOG_LEVEL=INFO

# Database Configuration
DATABASE_URL=sqlite:///./app.db
# For PostgreSQL: postgresql://user:password@localhost:5432/linebot_db

# External API Keys
ALPHA_VANTAGE_API_KEY=your_api_key_here

# API Timeout Settings (seconds)
API_TIMEOUT=20
INDEX_FETCH_TIMEOUT=5
STOCK_FETCH_TIMEOUT=5
NEWS_FETCH_TIMEOUT=10

# Cache Settings
CACHE_INDEX_TTL_MINUTES=5
CACHE_STOCK_TTL_MINUTES=5
CACHE_NEWS_TTL_HOURS=1
CACHE_TW_STOCK_TTL_HOURS=24

# Feature Flags
ENABLE_TW_STOCK_LOOKUP=true
ENABLE_NEWS_TRANSLATION=false

# Logging
LOG_FORMAT=json
LOG_FILE=logs/app.log
